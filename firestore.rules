rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }

    function isValidSiteContent(data) {
      return data.keys().hasAll(['note', 'updatedAt', 'updatedBy'])
          && data.note is string && data.note.size() <= 10000
          && data.updatedBy == request.auth.uid;
    }

    match /content/{contentId} {
      allow read: if true;
      // Triggers new deployment
      allow create: if isSignedIn() 
                    && isValidId(contentId) 
                    && isValidSiteContent(incoming()) 
                    && incoming().keys().size() == 3
                    && incoming().updatedAt == request.time;
                    
      allow update: if isSignedIn()
                    && isValidId(contentId)
                    && isValidSiteContent(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['note', 'updatedAt', 'updatedBy'])
                    && incoming().updatedAt == request.time;
    }

    match /gallery_photos/{photoId} {
      allow read, write: if true;
    }

    match /pop_memories/{memoryId} {
      allow read, write: if true;
    }

    match /casual_photos/{photoId} {
      allow read, write: if true;
    }
  }
}
